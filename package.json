    "pino": "^8.21.0",
    "pino-pretty": "^10.2.3",
    "qrcode-terminal": "^0.12.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.37",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/sqlite3": "^3.1.11",
