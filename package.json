{
  "name": "seguritech-bot-pro",
  "version": "1.0.0",
  "description": "Professional WhatsApp Chatbot with Hexagonal Architecture",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "stop:pm2": "pm2 stop all",
    "logs": "pm2 logs",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "whatsapp",
    "chatbot",
    "baileys",
    "typescript",
    "hexagonal"
  ],
  "author": "SegurITech",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "pino": "^8.17.0",
    "pino-pretty": "^10.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "pm2": "^5.3.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
