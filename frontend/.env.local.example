# SegurITech Bot Pro - Frontend NextAuth Configuration

# ========================================================================
# 🔐 NEXTAUTH CONFIGURATION
# ========================================================================
# Secret para firmar sesiones de NextAuth (generar con: openssl rand -base64 32)
NEXTAUTH_SECRET=tu_nextauth_secret_super_largo_generado_aleatoriamente

# URL base de la aplicación (cambiar en producción)
NEXTAUTH_URL=http://localhost:3000

# ========================================================================
# ☁️  SUPABASE CONFIGURATION
# ========================================================================
# URL pública de Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública de Supabase (anónima, segura para client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de service role de Supabase (PRIVADA, solo servidor - NUNCA en .env.local en clientSi no lo necesitas, déjalo en blanco)
SUPABASE_SERVICE_ROLE_KEY=

# ========================================================================
# 🔌 BACKEND API
# ========================================================================
# URL del backend para llamadas API
BACKEND_API_URL=http://localhost:3001

