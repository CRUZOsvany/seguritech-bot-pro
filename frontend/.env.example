# ============================================================================
# SegurITech Bot Pro — Frontend (Next.js)
# Copia este archivo como .env.local y llena los valores reales.
# NUNCA commitees el .env.local real al repositorio.
# ============================================================================

# --- Entorno ---
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development

# --- NextAuth ---
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Supabase ---
# Variables NEXT_PUBLIC_* se exponen al cliente. Solo anon key aquí.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key — solo server-side. Bypasea RLS. Mantener secreta.
SUPABASE_SERVICE_ROLE_KEY=

# --- Backend API ---
# URL del servicio backend (Express). En docker-compose es http://backend:3001
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3001

# Debe coincidir con BACKEND_API_KEY del backend.
NEXT_PUBLIC_BACKEND_API_KEY=

# Si es 'true', el login muestra las credenciales de prueba en la UI.
# DEJAR VACÍO O AUSENTE EN STAGING/PRODUCCIÓN.
NEXT_PUBLIC_SHOW_DEV_CREDENTIALS=true