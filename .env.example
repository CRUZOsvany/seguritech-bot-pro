# SegurITech Bot Pro
# Professional WhatsApp Chatbot with Hexagonal Architecture

# Environment Variables
NODE_ENV=development

# Logger
LOG_LEVEL=debug

# WhatsApp (Baileys)
WHATSAPP_PHONE_NUMBER=
WHATSAPP_SESSION_NAME=seguritech-session
WHATSAPP_QR_TIMEOUT=30000

# Bot Configuration
BOT_NAME=SegurITech Bot
BOT_PREFIX=
BOT_AUTO_REPLY_ENABLED=true

# Database (Future)
DATABASE_URL=

# API (Future)
API_KEY=
API_URL=

# PM2
PM2_INSTANCE_NAME=seguritech-bot-pro
