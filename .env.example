# SegurITech Bot Pro
# Professional WhatsApp Chatbot with Hexagonal Architecture & Multi-Tenant

# ========================================================================
# 📌 ENTORNO
# ========================================================================
NODE_ENV=development
LOG_LEVEL=debug

# ========================================================================
# 🔌 WEBHOOK
# ========================================================================
WEBHOOK_PORT=3001

# ========================================================================
# 🌐 META WHATSAPP CLOUD API
# ========================================================================
# Obtén estos valores de: https://developers.facebook.com/apps

# URL base de Meta Graph API
META_API_URL=https://graph.facebook.com/v21.0

# ID del número de teléfono WhatsApp registrado en Meta
META_PHONE_NUMBER_ID=

# Token de acceso permanente de Meta (CRÍTICO: mantener secreto)
META_ACCESS_TOKEN=

# Token de verificación de webhook (defínelo tú mismo, min 32 caracteres)
META_VERIFY_TOKEN=tu_token_super_secreto_3hG9x2kL8mN_Abc123XyZ

# Secret para validar firmas HMAC de webhooks (defínelo tú mismo, min 32 caracteres)
META_APP_SECRET=tu_app_secret_super_secreto_9zK7w3pL5mN_Xyz789QrS

# ========================================================================
# 🤖 CONFIGURACIÓN DEL BOT
# ========================================================================
BOT_NAME=SegurITech Bot Pro

# ========================================================================
# 📊 BASE DE DATOS
# ========================================================================
DATABASE_URL=./database.sqlite

# ========================================================================
# ☁️  SUPABASE (Opcional)
# ========================================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ========================================================================
# 🔐 CORS
# ========================================================================
ALLOWED_ORIGINS=http://localhost:3000
