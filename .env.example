# ============================================================
# Meta WhatsApp Cloud API
# Puede quedar vacío para validar setup. Backend debe caer a
# ConsoleNotificationAdapter (loguear a stdout) si están vacíos.
# ============================================================
META_VERIFY_TOKEN=
META_APP_SECRET=

# Clave de cifrado para access_token de Meta. Genera con: openssl rand -hex 32
# Las credenciales por tenant (phone_number_id, waba_id, access_token) viven
# en la tabla tenant_meta_credentials, NO en este .env.
META_TOKEN_ENCRYPTION_KEY=

# ============================================================
# Supabase — backend (server-side, bypassea RLS)
# ============================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Supabase — frontend (build-time, se inlinea en el bundle)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================
# NextAuth
# Generar con: openssl rand -base64 32
# ============================================================
NEXTAUTH_SECRET=

# ============================================================
# API key compartida frontend ↔ backend
# Generar con: openssl rand -hex 32
# Debe ser idéntica en ambos servicios.
# ============================================================
BACKEND_API_KEY=
