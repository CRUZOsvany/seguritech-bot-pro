# SegurITech Bot Pro
# Professional WhatsApp Chatbot with Hexagonal Architecture & Multi-Tenant

# ========================================================================
# 📌 ENTORNO
# ========================================================================
NODE_ENV=development
LOG_LEVEL=debug

# ========================================================================
# 📱 WHATSAPP - BAILEYS (Legacy/Alternativa)
# ========================================================================
WHATSAPP_PHONE_NUMBER=
WHATSAPP_SESSION_NAME=seguritech-session
WHATSAPP_QR_TIMEOUT=30000
WEBHOOK_PORT=3001
WEBHOOK_TOKEN=tu_token_secreto_local

# ========================================================================
# 🔌 META WHATSAPP CLOUD API (Recomendado - Nuevo)
# ========================================================================
# Obtén estos valores de: https://developers.facebook.com/apps

# Nombre del token de verificación (lo defines tú)
# Debe coincidir con el valor en Meta Dashboard
META_VERIFY_TOKEN=tu_token_super_secreto_3hG9x2kL8mN_Abc123XyZ

# ID del número de teléfono WhatsApp registrado en Meta
# Ubicación: WhatsApp Manager → Números de teléfono
# Ejemplo: 102345678901234
META_PHONE_NUMBER_ID=

# Token de acceso permanente de Meta
# CRÍTICO: Mantener secreto. NO subir a Git sin encripción
# Ubicación: App → Settings → Tokens de sistema → Token de acceso
# Formato: EAAx...xyz (muy largo, 200+ caracteres)
META_ACCESS_TOKEN=

# URL base de Meta Graph API (actualizar a versiones estables)
META_API_URL=https://graph.instagram.com/v19.0

# ========================================================================
# 🤖 CONFIGURACIÓN DEL BOT
# ========================================================================
BOT_NAME=SegurITech Bot Pro
BOT_PREFIX=
BOT_AUTO_REPLY_ENABLED=true

# ========================================================================
# 📊 BASE DE DATOS
# ========================================================================
DATABASE_URL=sqlite:./seguritech.db

# ========================================================================
# 🔐 API INTEGRADA
# ========================================================================
API_KEY=
API_URL=

# ========================================================================
# 🔄 PM2
# ========================================================================
PM2_INSTANCE_NAME=seguritech-bot-pro
