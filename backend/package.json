{
  "name": "seguritech-bot-pro",
  "version": "1.0.0",
  "description": "Professional WhatsApp Chatbot with Hexagonal Architecture",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "stop:pm2": "pm2 stop all",
    "logs": "pm2 logs",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "jest --detectOpenHandles --forceExit --runInBand",
    "test:watch": "jest --watch --detectOpenHandles",
    "test:coverage": "jest --coverage --detectOpenHandles --forceExit",
    "test:integration": "jest --testPathPattern=integration --detectOpenHandles --forceExit --runInBand",
    "test:multiTenant": "jest multiTenantFlow --detectOpenHandles --forceExit --runInBand --verbose",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:types": "supabase gen types typescript --local > src/infrastructure/services/supabase.types.ts",
    "supabase:reset": "supabase db reset && npm run supabase:types"
  },
  "keywords": [
    "whatsapp",
    "chatbot",
    "typescript",
    "hexagonal",
    "saas",
    "multi-tenant"
  ],
  "author": "SegurITech",
  "license": "MIT",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@supabase/supabase-js": "^2.38.5",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^5.0.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "node-cache": "^5.1.2",
    "pino": "^8.21.0",
    "pino-pretty": "^10.2.3",
    "tsconfig-paths": "^4.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.37",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.10.0",
    "jest": "^30.3.0",
    "pm2": "^7.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
