# ============================================================================
# SegurITech Bot Pro — Backend
# Copia este archivo como .env y llena los valores reales.
# NUNCA commitees el .env real al repositorio.
# ============================================================================

# --- Entorno ---
NODE_ENV=development
LOG_LEVEL=info

# --- Webhook server (Express) ---
WEBHOOK_PORT=3001

# --- Meta Cloud API (WhatsApp Business oficial) ---
# Crea tu app en https://developers.facebook.com/apps
META_API_URL=https://graph.facebook.com/v21.0

# Token de verificación del webhook. Mínimo 32 caracteres.
# Genera uno con: openssl rand -hex 32
META_VERIFY_TOKEN=

# Secret de la app (Meta Developers > Basic Settings). Mínimo 32 caracteres.
# Usado para verificar la firma HMAC-SHA256 de cada webhook entrante.
META_APP_SECRET=

# Clave de cifrado para access_token de Meta. Genera con: openssl rand -hex 32
META_TOKEN_ENCRYPTION_KEY=

# NOTA: las credenciales de Meta por tenant (phone_number_id, waba_id,
# access_token) viven en la tabla tenant_meta_credentials, NO en el .env.

# --- Bot ---
BOT_NAME=SegurITech Bot

# --- Supabase (Postgres + Auth gestionado — ÚNICA persistencia) ---
# https://app.supabase.com -> Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co

# service_role key — bypasea RLS. NUNCA expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000

# --- Admin API ---
# Header x-api-key que protege las rutas /api/admin/* desde CLI/curl/scripts.
# Genera una con: openssl rand -hex 32
# Modos de auth aceptados por el panel (en orden de preferencia):
#   1) Cookie JWT (panel HTML — vía POST /api/auth/login)
#   2) Cloudflare Access (header Cf-Access-Authenticated-User-Email en prod)
#   3) x-api-key: este valor (CLI / scripts / curl)
# NOTA: el bypass loopback (dev + 127.0.0.1) fue REMOVIDO en Sprint F.
BACKEND_API_KEY=

# Cloudflare Access — dominio de email permitido para el panel admin en prod.
# Ej: "seguritech.com". Solo emails @seguritech.com pueden pasar.
# En dev local NO se usa.
CLOUDFLARE_ALLOWED_DOMAIN=

# ============================================================================
# Sesiones admin (Operación Búnker v2 — Sprint F)
# ============================================================================

# Secreto para firmar JWTs HS256 (>=64 chars).
# Genera con: openssl rand -hex 64
# En prod ES OBLIGATORIO. En dev, si está vacío se genera uno efímero por proceso.
ADMIN_JWT_SECRET=

# Tiempo de vida del JWT en segundos (default 8h = 28800)
ADMIN_JWT_TTL_SECONDS=28800

# Cookie name. En prod usar prefijo __Host- (impone Secure + Path=/ + sin Domain):
#   ADMIN_COOKIE_NAME=__Host-seguritech_session
ADMIN_COOKIE_NAME=seguritech_session

# Lockout por intentos fallidos (cuenta y/o IP)
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_MINUTES=15

# Bcrypt cost. 12 = ~250ms por compare en hardware promedio 2026.
ADMIN_BCRYPT_COST=12